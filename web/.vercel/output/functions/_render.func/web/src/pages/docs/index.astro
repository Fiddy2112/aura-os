---
import DocsLayout from '../../layouts/DocsLayout.astro';
import {Rocket,Terminal,Lock,Brain,Mic,Wallet,Hexagon, Package} from 'lucide-react';
---

<DocsLayout title="Documentation">
  <div class="mb-12">
    <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Documentation</h1>
    <p class="text-xl text-zinc-400">
      Everything you need to master Aura OS — your AI Commander for Web3.
    </p>
  </div>

  <div class="grid gap-6 md:grid-cols-2 mb-16">
    <a href="/docs/getting-started" class="bento-card group block">
      <div class="inline-flex items-center justify-center w-12 h-12 mb-4 rounded-xl bg-gradient-to-br from-purple-500/20 to-purple-600/10 border border-purple-500/20">
        <span class="text-2xl"><Rocket size={24}/></span>
      </div>
      <h3 class="text-xl font-semibold text-white mb-2 group-hover:text-purple-400 transition-colors">
        Getting Started
      </h3>
      <p class="text-zinc-400">
        Install Aura OS and set up your first AI-powered Web3 agent in minutes.
      </p>
    </a>

    <a href="/docs/commands" class="bento-card group block">
      <div class="inline-flex items-center justify-center w-12 h-12 mb-4 rounded-xl bg-gradient-to-br from-blue-500/20 to-blue-600/10 border border-blue-500/20">
        <span class="text-2xl"><Terminal size={24}/></span>
      </div>
      <h3 class="text-xl font-semibold text-white mb-2 group-hover:text-blue-400 transition-colors">
        CLI Commands
      </h3>
      <p class="text-zinc-400">
        Comprehensive reference for all Aura OS command-line commands and options.
      </p>
    </a>

    <a href="/docs/vault" class="bento-card group block">
      <div class="inline-flex items-center justify-center w-12 h-12 mb-4 rounded-xl bg-gradient-to-br from-green-500/20 to-green-600/10 border border-green-500/20">
        <span class="text-2xl"><Lock size={24}/></span>
      </div>
      <h3 class="text-xl font-semibold text-white mb-2 group-hover:text-green-400 transition-colors">
        Secure Vault
      </h3>
      <p class="text-zinc-400">
        Learn how Aura OS encrypts and protects your private keys locally.
      </p>
    </a>

    <a href="/docs/ai-interpreter" class="bento-card group block">
      <div class="inline-flex items-center justify-center w-12 h-12 mb-4 rounded-xl bg-gradient-to-br from-cyan-500/20 to-cyan-600/10 border border-cyan-500/20">
        <span class="text-2xl"><Brain size={24}/></span>
      </div>
      <h3 class="text-xl font-semibold text-white mb-2 group-hover:text-cyan-400 transition-colors">
        AI Interpreter
      </h3>
      <p class="text-zinc-400">
        Understand how the AI parses and validates your natural language commands.
      </p>
    </a>
  </div>

  <!-- Architecture Overview -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold text-white mb-6">Architecture Overview</h2>
    <div class="glass-card p-8">
      <div class="grid md:grid-cols-3 gap-6 text-center">
        <div class="p-4">
          <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-purple-500/10 border border-purple-500/20 flex items-center justify-center">
            <span class="text-3xl"><Mic size={24}/></span>
          </div>
          <h4 class="font-semibold text-white mb-2">Natural Language Input</h4>
          <p class="text-sm text-zinc-400">
            Speak your intent in English or Vietnamese
          </p>
        </div>
        <div class="p-4">
          <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center">
            <span class="text-3xl"><Terminal size={24}/></span>
          </div>
          <h4 class="font-semibold text-white mb-2">AI Processing</h4>
          <p class="text-sm text-zinc-400">
            GPT-4 powered intent parsing with Zod validation
          </p>
        </div>
        <div class="p-4">
          <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-green-500/10 border border-green-500/20 flex items-center justify-center">
            <span class="text-3xl"><Wallet size={24}/></span>
          </div>
          <h4 class="font-semibold text-white mb-2">On-Chain Execution</h4>
          <p class="text-sm text-zinc-400">
            Secure transaction signing and blockchain interaction
          </p>
        </div>
      </div>
      
      <div class="mt-8 flex justify-center">
        <div class="flex items-center gap-4 text-zinc-500">
          <span class="w-8 h-0.5 bg-gradient-to-r from-transparent to-purple-500"></span>
          <span>→</span>
          <span class="w-8 h-0.5 bg-gradient-to-r from-purple-500 to-blue-500"></span>
          <span>→</span>
          <span class="w-8 h-0.5 bg-gradient-to-r from-blue-500 to-green-500"></span>
          <span>→</span>
          <span class="w-8 h-0.5 bg-gradient-to-r from-green-500 to-transparent"></span>
        </div>
      </div>
    </div>
  </section>

  <!-- Project Structure -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold text-white mb-6">Project Structure</h2>
    <div class="terminal">
      <div class="terminal-header">
        <div class="terminal-dot bg-red-500"></div>
        <div class="terminal-dot bg-yellow-500"></div>
        <div class="terminal-dot bg-green-500"></div>
        <span class="ml-4 text-xs text-zinc-500 font-mono">aura-os/</span>
      </div>
      <div class="p-4 font-mono text-sm text-zinc-300">
        <pre class="text-zinc-400">
            aura-os/
            ├── src/
            │   ├── <span class="text-blue-400">index.ts</span>          <span class="text-zinc-600"># CLI entry point</span>
            │   ├── commands/
            │   │   ├── <span class="text-green-400">setup.ts</span>      <span class="text-zinc-600"># Wallet setup command</span>
            │   │   └── <span class="text-green-400">chat.ts</span>       <span class="text-zinc-600"># AI chat command</span>
            │   └── core/
            │       ├── ai/
            │       │   └── <span class="text-purple-400">interpreter.ts</span>  <span class="text-zinc-600"># AI intent parser</span>
            │       └── security/
            │           └── <span class="text-yellow-400">vault.ts</span>    <span class="text-zinc-600"># AES-256 encryption</span>
            ├── web/                  <span class="text-zinc-600"># Astro website</span>
            ├── package.json
            └── tsconfig.json
        </pre>
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold text-white mb-6">Tech Stack</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="glass-card p-4 text-center">
        <div class="text-2xl mb-2"><Hexagon size={24}/></div>
        <div class="text-sm font-semibold text-white">Node.js</div>
        <div class="text-xs text-zinc-500">Runtime</div>
      </div>
      <div class="glass-card p-4 text-center">
        <div class="text-2xl mb-2"><Package size={24}/></div>
        <div class="text-sm font-semibold text-white">OpenAI</div>
        <div class="text-xs text-zinc-500">AI Provider</div>
      </div>
      <div class="glass-card p-4 text-center">
        <div class="text-2xl mb-2"><Package size={24}/></div>
        <div class="text-sm font-semibold text-white">Viem</div>
        <div class="text-xs text-zinc-500">Ethereum</div>
      </div>
      <div class="glass-card p-4 text-center">
        <div class="text-2xl mb-2"><Lock size={24}/></div>
        <div class="text-sm font-semibold text-white">CryptoJS</div>
        <div class="text-xs text-zinc-500">Encryption</div>
      </div>
    </div>
  </section>

  <section class="glass-card p-8 text-center">
    <h2 class="text-2xl font-bold text-white mb-4">Need Help?</h2>
    <p class="text-zinc-400 mb-6">
      Join our community or check the source code for more details.
    </p>
    <div class="flex justify-center gap-4">
      <a href="https://github.com/aura-os" target="_blank" class="btn-secondary text-sm py-2 px-6">
        GitHub
      </a>
      <a href="https://discord.gg/auraos" target="_blank" class="btn-primary text-sm py-2 px-6">
        Discord
      </a>
    </div>
  </section>
</DocsLayout>
