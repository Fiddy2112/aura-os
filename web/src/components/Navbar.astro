---

---

<header class="fixed top-0 left-0 right-0 z-50">
  <div class="mx-4 mt-4">
    <nav class="glass-card px-6 py-4 flex items-center justify-between max-w-7xl mx-auto">

      <a href="/" class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center transition-transform group-hover:scale-105">
          <span class="text-black font-bold text-lg">A</span>
        </div>
        <span class="font-bold text-xl text-white">Aura OS</span>
      </a>

      <div class="hidden md:flex items-center gap-8">
        <a href="/features" class="text-sm text-zinc-400 hover:text-white transition-colors">Features</a>
        <a href="/chat" class="text-sm text-zinc-400 hover:text-white transition-colors">Chat</a>
        <a href="/docs" class="text-sm text-zinc-400 hover:text-white transition-colors">Docs</a>
        <a href="https://github.com/aura-os" target="_blank" rel="noopener" class="text-sm text-zinc-400 hover:text-white transition-colors flex items-center gap-1.5">
          GitHub
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
          </svg>
        </a>
      </div>

      <div class="flex items-center gap-4">
        <a href="/docs/getting-started" class="btn-primary text-sm py-2.5 px-6">
          Get Started
        </a>
        
        <button class="md:hidden p-2 text-zinc-400 hover:text-white" id="mobile-menu-btn">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <div class="hidden md:hidden mx-4 mt-2" id="mobile-menu">
    <div class="glass-card p-4 space-y-2">
      <a href="/features" class="block py-2 px-4 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-lg transition-colors">Features</a>
      <a href="/chat" class="block py-2 px-4 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-lg transition-colors">Chat</a>
      <a href="/docs" class="block py-2 px-4 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-lg transition-colors">Docs</a>
      <a href="https://github.com/aura-os" class="block py-2 px-4 text-zinc-400 hover:text-white hover:bg-zinc-800/50 rounded-lg transition-colors">GitHub</a>
    </div>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  
  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
