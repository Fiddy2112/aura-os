---
const currentYear = new Date().getFullYear();
---

<footer class="relative py-20 border-t border-zinc-900 bg-black">
  <div class="section-container">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      <div class="md:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center">
            <span class="text-black font-bold text-lg">A</span>
          </div>
          <span class="font-bold text-xl text-white">Aura OS</span>
        </a>
        <p class="text-sm text-zinc-500 mb-6">
          Your AI Commander for Web3. Intelligent automation meets ironclad security.
        </p>
        <div class="flex items-center gap-4">
          <a href="https://twitter.com/auraos" target="_blank" rel="noopener" class="w-10 h-10 rounded-lg bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-500 hover:text-white hover:border-zinc-700 transition-all">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
            </svg>
          </a>
          <a href="https://github.com/aura-os" target="_blank" rel="noopener" class="w-10 h-10 rounded-lg bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-500 hover:text-white hover:border-zinc-700 transition-all">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"></path>
            </svg>
          </a>
          <a href="https://discord.gg/auraos" target="_blank" rel="noopener" class="w-10 h-10 rounded-lg bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-500 hover:text-white hover:border-zinc-700 transition-all">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.010c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"></path>
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Product</h4>
        <ul class="space-y-3">
          <li><a href="/features" class="text-sm text-zinc-500 hover:text-white transition-colors">Features</a></li>
          <li><a href="/docs" class="text-sm text-zinc-500 hover:text-white transition-colors">Documentation</a></li>
          <li><a href="/changelog" class="text-sm text-zinc-500 hover:text-white transition-colors">Changelog</a></li>
          <li><a href="/roadmap" class="text-sm text-zinc-500 hover:text-white transition-colors">Roadmap</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Resources</h4>
        <ul class="space-y-3">
          <li><a href="/docs/getting-started" class="text-sm text-zinc-500 hover:text-white transition-colors">Getting Started</a></li>
          <li><a href="/docs/commands" class="text-sm text-zinc-500 hover:text-white transition-colors">CLI Commands</a></li>
          <li><a href="/docs/api" class="text-sm text-zinc-500 hover:text-white transition-colors">API Reference</a></li>
          <li><a href="https://github.com/Fiddy2112/aura-os" class="text-sm text-zinc-500 hover:text-white transition-colors">GitHub</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Legal</h4>
        <ul class="space-y-3">
          <li><a href="/privacy" class="text-sm text-zinc-500 hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="text-sm text-zinc-500 hover:text-white transition-colors">Terms of Service</a></li>
          <li><a href="/security" class="text-sm text-zinc-500 hover:text-white transition-colors">Security</a></li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-zinc-900 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-sm text-zinc-600">
        © {currentYear} Aura OS. All rights reserved.
      </p>
      <p class="text-sm text-zinc-700">
        Built with ♥ for the Web3 community
      </p>
    </div>
  </div>
</footer>
