---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { Brain,Lock,Shield,Terminal } from 'lucide-react';
---

<Layout title="Features - Aura OS">
  <Navbar />
  
  <main class="pt-32 bg-black">
    <section class="section-container text-center mb-24">
      <span class="inline-block px-4 py-1.5 mb-6 text-sm font-medium text-zinc-400 border border-zinc-800 rounded-full">
        Features
      </span>
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-6">
        Everything you need to
        <br />
        <span class="text-zinc-500">dominate Web3</span>
      </h1>
      <p class="text-xl text-zinc-500 max-w-2xl mx-auto">
        From AI-powered automation to military-grade security, Aura OS is built for serious operators.
      </p>
    </section>

    <section class="section-container mb-32">
      <div class="grid gap-8">
        
        <div class="glass-card p-8 md:p-12">
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div>
              <div class="inline-flex items-center justify-center w-16 h-16 mb-6 rounded-2xl bg-zinc-800 border border-zinc-700">
                <span class="text-3xl"><Brain size={24}/></span>
              </div>
              <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">AI Brain</h2>
              <p class="text-lg text-zinc-400 mb-6">
                Powered by GPT-4, Aura understands your commands in natural language. 
                Speak Vietnamese, English, or any language — Aura gets it.
              </p>
              <ul class="space-y-4">
                <li class="flex items-start gap-3">
                  <span class="w-6 h-6 rounded-full bg-zinc-800 flex items-center justify-center text-white text-sm mt-0.5">✓</span>
                  <div>
                    <span class="text-white font-medium">Intent Recognition</span>
                    <p class="text-sm text-zinc-500">Automatically parse CHECK_BALANCE, SEND_TOKEN, SWAP_TOKEN actions</p>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <span class="w-6 h-6 rounded-full bg-zinc-800 flex items-center justify-center text-white text-sm mt-0.5">✓</span>
                  <div>
                    <span class="text-white font-medium">Schema Validation</span>
                    <p class="text-sm text-zinc-500">Zod-powered validation ensures type-safe outputs</p>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <span class="w-6 h-6 rounded-full bg-zinc-800 flex items-center justify-center text-white text-sm mt-0.5">✓</span>
                  <div>
                    <span class="text-white font-medium">Multi-language Support</span>
                    <p class="text-sm text-zinc-500">Works in Vietnamese, English, and more</p>
                  </div>
                </li>
              </ul>
            </div>
            <div class="flex justify-center">
              <div class="terminal w-full max-w-md overflow-hidden">
                <div class="terminal-header">
                  <div class="terminal-dot bg-red-600"></div>
                  <div class="terminal-dot bg-yellow-600"></div>
                  <div class="terminal-dot bg-green-600"></div>
                </div>
                <div class="p-4 font-mono text-sm space-y-2 overflow-x-auto whitespace-nowrap">
                  <div><span class="text-zinc-500">$</span> aura chat "Kiểm tra số dư ETH"</div>
                  <div class="text-zinc-500">Aura is thinking...</div>
                  <div class="text-white">✓ Valid command: CHECK_BALANCE</div>
                  <div class="text-zinc-400">  Token: ETH</div>
                  <div class="text-zinc-400">  Balance: 2.847 ETH</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="glass-card p-8 md:p-12">
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div class="order-2 md:order-1 flex justify-center">
              <div class="w-64 h-64 relative">
                <div class="absolute inset-0 rounded-3xl bg-zinc-900 border border-zinc-800 flex items-center justify-center">
                  <div class="text-center">
                    <div class="text-6xl mb-4"><Lock size={64}/></div>
                    <div class="text-white font-mono">AES-256</div>
                    <div class="text-zinc-500 text-sm">Encrypted</div>
                  </div>
                </div>
              </div>
            </div>
            <div class="order-1 md:order-2">
              <div class="inline-flex items-center justify-center w-16 h-16 mb-6 rounded-2xl bg-zinc-800 border border-zinc-700">
                <span class="text-3xl"><Shield size={24}/></span>
              </div>
              <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Secure Vault</h2>
              <p class="text-lg text-zinc-400 mb-6">
                Your private keys never leave your device. Military-grade AES-256 encryption 
                protects your assets — no cloud, no compromise.
              </p>
              <ul class="space-y-4">
                <li class="flex items-start gap-3">
                  <span class="w-6 h-6 rounded-full bg-zinc-800 flex items-center justify-center text-white text-sm mt-0.5">✓</span>
                  <div>
                    <span class="text-white font-medium">Local-Only Storage</span>
                    <p class="text-sm text-zinc-500">Keys encrypted and stored on your machine only</p>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <span class="w-6 h-6 rounded-full bg-zinc-800 flex items-center justify-center text-white text-sm mt-0.5">✓</span>
                  <div>
                    <span class="text-white font-medium">Master Password</span>
                    <p class="text-sm text-zinc-500">Single password to unlock your vault</p>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <span class="w-6 h-6 rounded-full bg-zinc-800 flex items-center justify-center text-white text-sm mt-0.5">✓</span>
                  <div>
                    <span class="text-white font-medium">Zero Server Dependency</span>
                    <p class="text-sm text-zinc-500">Works completely offline</p>
                  </div>
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- CLI Power Feature -->
        <div class="glass-card p-8 md:p-12">
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div>
              <div class="inline-flex items-center justify-center w-16 h-16 mb-6 rounded-2xl bg-zinc-800 border border-zinc-700">
                <span class="text-3xl"><Terminal size={24}/></span>
              </div>
              <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">CLI Power</h2>
              <p class="text-lg text-zinc-400 mb-6">
                Runs silently in the background as a daemon. Automate complex tasks that 
                browsers can't handle — monitoring, trading, alerts.
              </p>
              <ul class="space-y-4">
                <li class="flex items-start gap-3">
                  <span class="w-6 h-6 rounded-full bg-zinc-800 flex items-center justify-center text-white text-sm mt-0.5">✓</span>
                  <div>
                    <span class="text-white font-medium">Background Agents</span>
                    <p class="text-sm text-zinc-500">Deploy autonomous trading and monitoring agents</p>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <span class="w-6 h-6 rounded-full bg-zinc-800 flex items-center justify-center text-white text-sm mt-0.5">✓</span>
                  <div>
                    <span class="text-white font-medium">Real-time Alerts</span>
                    <p class="text-sm text-zinc-500">Get notified when conditions are met</p>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <span class="w-6 h-6 rounded-full bg-zinc-800 flex items-center justify-center text-white text-sm mt-0.5">✓</span>
                  <div>
                    <span class="text-white font-medium">Scriptable</span>
                    <p class="text-sm text-zinc-500">Chain commands and build workflows</p>
                  </div>
                </li>
              </ul>
            </div>
            <div class="flex justify-center">
              <div class="terminal w-full max-w-md overflow-hidden">
                <div class="terminal-header">
                  <div class="terminal-dot bg-red-600"></div>
                  <div class="terminal-dot bg-yellow-600"></div>
                  <div class="terminal-dot bg-green-600"></div>
                </div>
                <div class="p-4 font-mono text-sm space-y-1 overflow-x-auto whitespace-nowrap">
                  <div><span class="text-zinc-500">$</span> aura agent start \</div>
                  <div class="pl-4">--task "monitor whale wallets" \</div>
                  <div class="pl-4">--alert telegram \</div>
                  <div class="pl-4">--threshold 100eth</div>
                  <div class="text-white mt-2">✓ Agent deployed</div>
                  <div class="text-zinc-400">  Monitoring 847 wallets...</div>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <section class="section-container mb-32">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Multi-Chain Support</h2>
        <p class="text-lg text-zinc-500">One interface, every chain.</p>
      </div>
      <div class="flex flex-wrap justify-center gap-6">
        <div class="glass-card p-6 flex items-center gap-4 min-w-[200px]">
          <div class="w-12 h-12 rounded-full bg-zinc-800 flex items-center justify-center text-2xl border border-zinc-700">
            <img src="/ethereum.svg" alt="Ethereum" class="w-6 h-6" />
          </div>
          <div>
            <div class="text-white font-semibold">Ethereum</div>
            <div class="text-sm text-zinc-500">Mainnet + L2s</div>
          </div>
        </div>
        <div class="glass-card p-6 flex items-center gap-4 min-w-[200px]">
          <div class="w-12 h-12 rounded-full bg-zinc-800 flex items-center justify-center text-2xl border border-zinc-700">
            <img src="/sui.svg" alt="SUI" class="w-6 h-6" />
          </div>
          <div>
            <div class="text-white font-semibold">Sui</div>
            <div class="text-sm text-zinc-500">Move-based</div>
          </div>
        </div>
        <div class="glass-card p-6 flex items-center gap-4 min-w-[200px]">
          <div class="w-12 h-12 rounded-full bg-zinc-800 flex items-center justify-center text-2xl border border-zinc-700">🔵</div>
          <div>
            <div class="text-white font-semibold">Base</div>
            <div class="text-sm text-zinc-500">Coinbase L2</div>
          </div>
        </div>
        <div class="glass-card p-6 flex items-center gap-4 min-w-[200px]">
          <div class="w-12 h-12 rounded-full bg-zinc-800 flex items-center justify-center text-xl border border-dashed border-zinc-700 text-zinc-500">+5</div>
          <div>
            <div class="text-white font-semibold">More coming</div>
            <div class="text-sm text-zinc-500">Arbitrum, Optimism...</div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-container mb-32">
      <div class="glass-card p-12 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Ready to get started?</h2>
        <p class="text-lg text-zinc-500 mb-8 max-w-xl mx-auto">
          Install Aura OS in seconds and start commanding the blockchain.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/docs/getting-started" class="btn-primary">
            Get Started
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
          <a href="/docs" class="btn-secondary">
            Read Docs
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
