        <div class="text-zinc-400">  Invested: 12.40 ETH | Current: 15.82 ETH</div>
        <div class="text-green-400">  Gain:     +3.42 ETH (+27.6% ROI)</div>
      </div>
    </div>
  </section>

  <section class="mb-16" id="swap">
    <div class="flex items-center gap-3 mb-4">
