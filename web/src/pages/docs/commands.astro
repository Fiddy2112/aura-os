        <div class="text-green-400">✓ Results returned</div>
      </div>
    </div>
  </section>

  <section class="mb-16" id="decode">
    <div class="flex items-center gap-3 mb-4">
      <code class="px-3 py-1.5 bg-yellow-500/10 text-yellow-400 rounded-lg font-mono text-lg">aura decode &lt;calldata&gt; [--abi &lt;file&gt;]</code>
    </div>
    <p class="text-zinc-300 leading-relaxed mb-6">
      Decode raw transaction calldata into a human-readable function signature and argument list. Resolves ABI automatically from Etherscan, or accepts a local <code>--abi my.json</code> file.
