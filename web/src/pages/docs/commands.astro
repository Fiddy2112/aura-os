    <div class="terminal mb-6">
      <div class="p-4 font-mono text-sm space-y-1">
        <div><span class="text-purple-400">❯</span> <span class="text-green-400">aura pnl</span> <span class="text-yellow-400">0xd8dA6BF...</span></div>
