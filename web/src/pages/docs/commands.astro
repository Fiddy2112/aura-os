    <div class="terminal mb-6">
      <div class="p-4 font-mono text-sm space-y-1">
        <div><span class="text-purple-400">❯</span> <span class="text-green-400">aura decode</span> <span class="text-yellow-400">0xa9059cbb000000000000000000000000...</span></div>
        <div class="text-cyan-400 mt-2">  Function: transfer(address to, uint256 amount)</div>
        <div class="text-zinc-400">  to:       0xd8dA6BF...</div>
