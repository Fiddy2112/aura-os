---
import DocsLayout from '../../../layouts/DocsLayout.astro';
---

<DocsLayout title="aura chat">
  <nav class="flex items-center gap-2 text-sm text-zinc-500 mb-8">
    <a href="/docs" class="hover:text-white transition-colors">Docs</a>
    <span>/</span>
    <a href="/docs/commands" class="hover:text-white transition-colors">Commands</a>
    <span>/</span>
    <span class="text-white">aura chat</span>
  </nav>

  <div class="mb-12">
    <div class="px-3 py-1 rounded-full bg-zinc-800 text-xs font-mono text-zinc-400 inline-block mb-4">command</div>
    <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 font-mono">aura chat</h1>
    <p class="text-xl text-zinc-400">Execute Web3 commands using natural language.</p>
  </div>

  <div class="glass-card p-6 mb-12">
    <h3 class="text-sm font-semibold text-zinc-500 uppercase tracking-wider mb-4">Synopsis</h3>
    <div class="terminal">
      <div class="p-4 font-mono text-sm">
        <span class="text-green-400">aura chat</span> <span class="text-cyan-400">"&lt;your command in natural language&gt;"</span>
      </div>
    </div>
  </div>

  <section class="mb-16">
    <h2 class="text-2xl font-bold text-white mb-4">Description</h2>
    <p class="text-zinc-300 leading-relaxed mb-4">
      The <code class="px-2 py-1 bg-zinc-800 rounded text-purple-400">aura chat</code> command is the primary way to interact with Aura OS. 
      Simply describe what you want in plain English (or Vietnamese), and Aura's AI will understand and execute it.
    </p>
    <p class="text-zinc-300">
      The AI interprets your request, extracts the intent, and executes the appropriate blockchain action.
    </p>
  </section>

  <section class="mb-16">
    <h2 class="text-2xl font-bold text-white mb-4">Supported Actions</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead>
          <tr class="border-b border-zinc-800">
            <th class="py-3 px-4 text-zinc-400">Action</th>
            <th class="py-3 px-4 text-zinc-400">Description</th>
            <th class="py-3 px-4 text-zinc-400">Requires Wallet</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-zinc-800/50">
            <td class="py-3 px-4"><code class="text-purple-400">CHECK_BALANCE</code></td>
            <td class="py-3 px-4 text-zinc-300">View token balance</td>
            <td class="py-3 px-4 text-green-400">Yes</td>
          </tr>
          <tr class="border-b border-zinc-800/50">
            <td class="py-3 px-4"><code class="text-purple-400">SEND_TOKEN</code></td>
            <td class="py-3 px-4 text-zinc-300">Transfer tokens</td>
            <td class="py-3 px-4 text-green-400">Yes</td>
          </tr>
          <tr class="border-b border-zinc-800/50">
            <td class="py-3 px-4"><code class="text-purple-400">SWAP_TOKEN</code></td>
            <td class="py-3 px-4 text-zinc-300">Swap tokens</td>
            <td class="py-3 px-4 text-green-400">Yes</td>
          </tr>
          <tr class="border-b border-zinc-800/50">
            <td class="py-3 px-4"><code class="text-purple-400">GET_PRICE</code></td>
            <td class="py-3 px-4 text-zinc-300">Token price in USD</td>
            <td class="py-3 px-4 text-zinc-500">No</td>
          </tr>
          <tr class="border-b border-zinc-800/50">
            <td class="py-3 px-4"><code class="text-purple-400">GET_GAS</code></td>
            <td class="py-3 px-4 text-zinc-300">Current gas price</td>
            <td class="py-3 px-4 text-zinc-500">No</td>
          </tr>
          <tr class="border-b border-zinc-800/50">
            <td class="py-3 px-4"><code class="text-purple-400">GET_ADDRESS</code></td>
            <td class="py-3 px-4 text-zinc-300">Show wallet address</td>
            <td class="py-3 px-4 text-green-400">Yes</td>
          </tr>
          <tr class="border-b border-zinc-800/50">
            <td class="py-3 px-4"><code class="text-purple-400">GET_TRANSACTIONS</code></td>
            <td class="py-3 px-4 text-zinc-300">Transaction history</td>
            <td class="py-3 px-4 text-zinc-500">No</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="mb-16">
    <h2 class="text-2xl font-bold text-white mb-4">Examples</h2>
    
    <div class="space-y-4">
      <div class="terminal">
        <div class="terminal-header">
          <div class="terminal-dot bg-red-500"></div>
          <div class="terminal-dot bg-yellow-500"></div>
          <div class="terminal-dot bg-green-500"></div>
          <span class="ml-4 text-xs text-zinc-500">Check Balance</span>
        </div>
        <div class="p-4 font-mono text-sm">
          <div><span class="text-purple-400">❯</span> <span class="text-green-400">aura chat "Check my ETH balance"</span></div>
          <div class="text-cyan-400 mt-2">Balance: 2.847 ETH</div>
        </div>
      </div>

      <div class="terminal">
        <div class="terminal-header">
          <div class="terminal-dot bg-red-500"></div>
          <div class="terminal-dot bg-yellow-500"></div>
          <div class="terminal-dot bg-green-500"></div>
          <span class="ml-4 text-xs text-zinc-500">Get Price</span>
        </div>
        <div class="p-4 font-mono text-sm">
          <div><span class="text-purple-400">❯</span> <span class="text-green-400">aura chat "What's the price of BTC?"</span></div>
          <div class="text-cyan-400 mt-2">Price: $67,890.42</div>
        </div>
      </div>

      <div class="terminal">
        <div class="terminal-header">
          <div class="terminal-dot bg-red-500"></div>
          <div class="terminal-dot bg-yellow-500"></div>
          <div class="terminal-dot bg-green-500"></div>
          <span class="ml-4 text-xs text-zinc-500">Send Tokens</span>
        </div>
        <div class="p-4 font-mono text-sm">
          <div><span class="text-purple-400">❯</span> <span class="text-green-400">aura chat "Send 0.1 ETH to 0x742d..."</span></div>
          <div class="text-yellow-400 mt-2">? Confirm sending 0.1 ETH? (y/N)</div>
        </div>
      </div>

      <div class="terminal">
        <div class="terminal-header">
          <div class="terminal-dot bg-red-500"></div>
          <div class="terminal-dot bg-yellow-500"></div>
          <div class="terminal-dot bg-green-500"></div>
          <span class="ml-4 text-xs text-zinc-500">Transaction History</span>
        </div>
        <div class="p-4 font-mono text-sm">
          <div><span class="text-purple-400">❯</span> <span class="text-green-400">aura chat "Show transactions for 0x742d..."</span></div>
          <div class="text-cyan-400 mt-2">Aura's Ledger Report: ...</div>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-16">
    <h2 class="text-2xl font-bold text-white mb-4">Supported Tokens & Chains</h2>
    <div class="grid gap-4 md:grid-cols-2">
      <div class="glass-card p-5">
        <h3 class="font-semibold text-white mb-3">Tokens</h3>
        <div class="flex flex-wrap gap-2">
          <span class="px-3 py-1 bg-zinc-800 rounded-full text-sm">ETH</span>
          <span class="px-3 py-1 bg-zinc-800 rounded-full text-sm">USDT</span>
          <span class="px-3 py-1 bg-zinc-800 rounded-full text-sm">USDC</span>
          <span class="px-3 py-1 bg-zinc-800 rounded-full text-sm">WETH</span>
          <span class="px-3 py-1 bg-zinc-800 rounded-full text-sm">BTC*</span>
        </div>
        <p class="text-xs text-zinc-500 mt-2">*Price only</p>
      </div>
      <div class="glass-card p-5">
        <h3 class="font-semibold text-white mb-3">Chains</h3>
        <div class="flex flex-wrap gap-2">
          <span class="px-3 py-1 bg-zinc-800 rounded-full text-sm">Ethereum</span>
          <span class="px-3 py-1 bg-zinc-800 rounded-full text-sm">Sepolia</span>
          <span class="px-3 py-1 bg-zinc-800 rounded-full text-sm">Base</span>
          <span class="px-3 py-1 bg-zinc-800 rounded-full text-sm">Arbitrum</span>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-16">
    <h2 class="text-2xl font-bold text-white mb-4">How It Works</h2>
    <ol class="space-y-4">
      <li class="flex gap-4">
        <span class="w-8 h-8 rounded-full bg-zinc-800 flex items-center justify-center text-sm shrink-0">1</span>
        <div>
          <h4 class="font-semibold text-white">Quick Parse</h4>
          <p class="text-sm text-zinc-400">Regex-based instant matching for common patterns</p>
        </div>
      </li>
      <li class="flex gap-4">
        <span class="w-8 h-8 rounded-full bg-zinc-800 flex items-center justify-center text-sm shrink-0">2</span>
        <div>
          <h4 class="font-semibold text-white">AI Parse</h4>
          <p class="text-sm text-zinc-400">GPT-4 → Groq → Gemini fallback chain for complex queries</p>
        </div>
      </li>
      <li class="flex gap-4">
        <span class="w-8 h-8 rounded-full bg-zinc-800 flex items-center justify-center text-sm shrink-0">3</span>
        <div>
          <h4 class="font-semibold text-white">Execute</h4>
          <p class="text-sm text-zinc-400">Blockchain executor performs the action</p>
        </div>
      </li>
    </ol>
  </section>

  <footer class="pt-8 border-t border-zinc-800/50">
    <div class="flex items-center justify-between text-sm text-zinc-500">
      <a href="/docs/commands/setup" class="hover:text-white transition-colors">← aura setup</a>
      <a href="/docs/ai-interpreter" class="hover:text-white transition-colors">AI Interpreter →</a>
    </div>
  </footer>
</DocsLayout>
