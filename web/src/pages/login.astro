---
import Layout from '../layouts/Layout.astro';
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<Layout title="Login | Aura OS">
  <main class="relative min-h-screen flex items-center justify-center overflow-hidden bg-black select-none">
    <!-- Dynamic Background -->
    <div class="absolute inset-0 z-0">
      <div class="absolute top-[20%] left-[20%] w-96 h-96 bg-purple-500/20 rounded-full blur-[100px] animate-pulse-slow"></div>
      <div class="absolute bottom-[20%] right-[20%] w-96 h-96 bg-blue-500/20 rounded-full blur-[100px] animate-pulse-slow" style="animation-delay: 1s;"></div>
      <div class="absolute inset-0 grid-pattern opacity-20"></div>
    </div>

    <!-- Login Container -->
    <div class="relative z-10 w-full max-w-md p-6">
      
      <!-- Glass Card -->
      <div class="backdrop-blur-xl bg-zinc-900/40 border border-white/10 rounded-3xl p-8 shadow-2xl ring-1 ring-white/5 relative overflow-hidden group hover:ring-white/10 transition-all duration-500">
        
        <!-- Shine Effect -->
        <div class="absolute inset-0 bg-gradient-to-tr from-white/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

        <!-- Header -->
        <div class="text-center mb-10">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-zinc-800 to-black border border-white/10 shadow-lg mb-6 group-hover:scale-105 transition-transform duration-300">
            <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h1 class="text-3xl font-bold text-white mb-2 tracking-tight">Welcome Back</h1>
          <p class="text-zinc-400 text-sm">Sign in to continue to Aura OS</p>
        </div>

        <!-- Auth Options -->
        <div class="space-y-4">
          <!-- Web3 Login -->
          <button id="btn-web3" class="relative w-full group overflow-hidden bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 p-[1px] rounded-xl hover:shadow-[0_0_20px_rgba(168,85,247,0.4)] transition-all duration-300">
            <div class="relative bg-black/90 backdrop-blur-sm rounded-[11px] p-4 flex items-center justify-center gap-3 transition-colors group-hover:bg-black/80">
              <svg class="w-5 h-5 text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 12V7H5a2 2 0 0 1 0-4h14v4" />
                <path d="M3 5v14a2 2 0 0 0 2 2h16v-5" />
                <path d="M18 12a2 2 0 0 0 0 4h4v-4Z" />
              </svg>
              <span class="font-medium text-white group-hover:scale-[1.02] transition-transform">Connect Wallet</span>
            </div>
            <div class="loading-spinner hidden absolute right-4 top-1/2 -translate-y-1/2">
                <div class="w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
            </div>
          </button>

          <div class="relative py-2">
            <div class="absolute inset-0 flex items-center">
              <span class="w-full border-t border-white/10"></span>
            </div>
            <div class="relative flex justify-center text-xs uppercase">
              <span class="bg-transparent px-2 text-zinc-500">Or continue with</span>
            </div>
          </div>

          <!-- OAuth Buttons -->
          <div class="grid grid-cols-2 gap-4">
            <button id="btn-google" class="flex items-center justify-center gap-2 px-4 py-3 bg-white/5 hover:bg-white/10 border border-white/5 rounded-xl transition-all hover:scale-[1.02] text-sm font-medium text-zinc-300 hover:text-white">
              <svg class="w-5 h-5" viewBox="0 0 24 24">
                <path fill="currentColor" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                <path fill="currentColor" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                <path fill="currentColor" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                <path fill="currentColor" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
              </svg>
              Google
            </button>
            <button id="btn-github" class="flex items-center justify-center gap-2 px-4 py-3 bg-white/5 hover:bg-white/10 border border-white/5 rounded-xl transition-all hover:scale-[1.02] text-sm font-medium text-zinc-300 hover:text-white">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.399 1.02 0 2.047.133 3.006.4 2.29-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              GitHub
            </button>
          </div>
        </div>

        <!-- Status & Footer -->
        <div id="status-msg" class="mt-6 text-center text-xs font-mono h-4 text-transparent transition-colors duration-300">
          Status Message
        </div>
        
        <div class="mt-8 pt-6 border-t border-white/5 text-center">
            <a href="/" class="text-xs text-zinc-600 hover:text-zinc-400 transition-colors">Return to Home</a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<div id="login-config" 
  data-supabase-url={supabaseUrl} 
  data-supabase-key={supabaseKey}
  data-cli-url="http://localhost:9876/auth-callback"
  class="hidden"
></div>

<script>
  import { createClient, type SupabaseClient, type Provider, type User, type Session } from '@supabase/supabase-js';

  interface AuthPayload {
    provider: string;
    wallet?: string;
    user?: User;
    session?: Session;
  }

  // Get config from DOM
  const configEl = document.getElementById('login-config');
  const supabaseUrl = configEl?.dataset.supabaseUrl || '';
  const supabaseKey = configEl?.dataset.supabaseKey || '';
  const CLI_CALLBACK_URL = configEl?.dataset.cliUrl || 'http://localhost:9876/auth-callback';
  
  // Initialize Supabase
  let supabase: SupabaseClient | null = null;
  try {
    if (supabaseUrl && supabaseKey) {
      supabase = createClient(supabaseUrl, supabaseKey);
    } else {
      console.warn('Supabase credentials missing. syncing features may be limited.');
    }
  } catch (e) {
    console.error('Supabase init error:', e);
  }

  // Elements
  const statusEl = document.getElementById('status-msg');
  const btnWeb3 = document.getElementById('btn-web3');
  const btnGoogle = document.getElementById('btn-google');
  const btnGithub = document.getElementById('btn-github');

  function showStatus(msg: string, type = 'info') {
    if (!statusEl) return;
    statusEl.textContent = msg;
    statusEl.classList.remove('text-red-500', 'text-green-500', 'text-zinc-400', 'text-transparent');
    
    if (type === 'error') statusEl.classList.add('text-red-500');
    else if (type === 'success') statusEl.classList.add('text-green-500');
    else statusEl.classList.add('text-zinc-400');
  }

  async function notifyCLI(payload: AuthPayload) {
    try {
      showStatus('Syncing with Aura OS CLI...', 'info');
      await fetch(CLI_CALLBACK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      showStatus('Successfully connected to Aura OS!', 'success');
      
      // Close window after short delay if in popup
      setTimeout(() => {
        window.close();
        // If not closed (not a popup), show success
        showStatus('You can now close this tab.', 'success');
      }, 1500);
    } catch (e) {
      console.warn('CLI not listening', e);
      showStatus('Logged in (CLI not detected)', 'success');
      // Redirect to dashboard if CLI isn't listening
      setTimeout(() => window.location.href = '/dashboard', 1000);
    }
  }

  // --- OAUTH LOGIN ---
  async function handleOAuth(provider: Provider) {
    if (!supabase) {
      showStatus('Auth service not configured', 'error');
      return;
    }
    showStatus(`Connecting to ${provider}...`);
    const { error } = await supabase.auth.signInWithOAuth({
      provider,
      options: {
        redirectTo: window.location.href,
      }
    });
    if (error) showStatus(error.message, 'error');
  }

  // Add listeners
  if (btnGoogle) btnGoogle.addEventListener('click', () => handleOAuth('google'));
  if (btnGithub) btnGithub.addEventListener('click', () => handleOAuth('github'));

  // --- WEB3 LOGIN ---
  if (btnWeb3) {
    btnWeb3.addEventListener('click', async () => {
      // @ts-ignore
      if (typeof window.ethereum === 'undefined') {
        showStatus('MetaMask not installed', 'error');
        return;
      }

      try {
        showStatus('Requesting wallet access...');
        // @ts-ignore
        const accounts = await window.ethereum.request({ method: 'eth_requestAccounts' });
        const address = accounts[0];
        
        await notifyCLI({
          provider: 'metamask',
          wallet: address
        });
      } catch (err) {
        showStatus((err as Error).message || 'Details rejected', 'error');
      }
    });
  }

  // --- CHECK SESSION ON LOAD ---
  if (supabase) {
    supabase.auth.getSession().then(({ data: { session } }) => {
      if (session) {
        // We have a session!
        // Send to CLI
        notifyCLI({
          provider: session.user.app_metadata.provider || 'oauth',
          user: session.user,
          session: session
        });
      }
    });
  }
</script>

<style>
  .animate-pulse-slow {
    animation: pulse 8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.2; transform: scale(1); }
    50% { opacity: 0.25; transform: scale(1.1); }
  }
</style>
