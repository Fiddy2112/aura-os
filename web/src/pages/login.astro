---
import Layout from '../layouts/Layout.astro';
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<Layout title="Login | Aura OS">
  <main class="relative min-h-screen flex items-center justify-center overflow-hidden bg-black select-none">
    <!-- Dynamic Background -->
    <div class="absolute inset-0 z-0">
      <div class="absolute top-[20%] left-[20%] w-96 h-96 bg-purple-500/20 rounded-full blur-[100px] animate-pulse-slow"></div>
      <div class="absolute bottom-[20%] right-[20%] w-96 h-96 bg-blue-500/20 rounded-full blur-[100px] animate-pulse-slow" style="animation-delay: 1s;"></div>
      <div class="absolute inset-0 grid-pattern opacity-20"></div>
    </div>

    <!-- Login Container -->
    <div class="relative z-10 w-full max-w-md p-6 animate-fade-in">
      
      <!-- Glass Card -->
      <div class="glass-card-premium p-10 shadow-2xl relative overflow-hidden group">
        
        <!-- Shine Effect -->
        <div class="absolute inset-0 bg-gradient-to-tr from-purple-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

        <!-- Header -->
        <div class="text-center mb-10">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-tr from-purple-600 to-cyan-500 p-[1px] neon-pulse mb-6 group-hover:rotate-3 transition-transform duration-500">
            <div class="w-full h-full rounded-2xl bg-zinc-950 flex items-center justify-center backdrop-blur-3xl">
              <span class="text-white font-black text-2xl tracking-tighter">A</span>
            </div>
          </div>
          <h1 class="text-3xl font-bold text-white mb-2 tracking-tight">Access <span class="text-purple-500">Aura</span></h1>
          <p class="text-zinc-500 text-sm font-medium">Link your account to sync the terminal.</p>
        </div>

        <!-- Auth Options -->
        <div id="auth-section" class="space-y-4">
          <!-- Web3 Login -->
          <button id="btn-web3" class="relative w-full group/btn overflow-hidden bg-white p-[1px] rounded-xl hover:shadow-[0_0_30px_rgba(255,255,255,0.2)] transition-all duration-300">
            <div class="relative bg-zinc-950 rounded-[11px] p-4 flex items-center justify-center gap-3 transition-colors group-hover/btn:bg-zinc-900">
              <div class="w-5 h-5 flex items-center justify-center">
                <div class="w-2 h-2 rounded-full bg-purple-500 neon-pulse"></div>
              </div>
              <span class="font-bold text-white tracking-tight uppercase text-xs">Connect Web3 Wallet</span>
            </div>
          </button>

          <div class="relative py-2">
            <div class="absolute inset-0 flex items-center">
              <span class="w-full border-t border-white/10"></span>
            </div>
            <div class="relative flex justify-center text-xs uppercase">
              <span class="bg-transparent px-2 text-zinc-500">Or continue with</span>
            </div>
          </div>

          <!-- OAuth Buttons -->
          <div class="grid grid-cols-2 gap-4">
            <button id="btn-google" class="flex items-center justify-center gap-2 px-4 py-3 bg-white/5 hover:bg-white/10 border border-white/5 rounded-xl transition-all hover:scale-[1.02] text-sm font-medium text-zinc-300 hover:text-white">
              <svg class="w-5 h-5" viewBox="0 0 24 24">
                <path fill="currentColor" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                <path fill="currentColor" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                <path fill="currentColor" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                <path fill="currentColor" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
              </svg>
              Google
            </button>
            <button id="btn-github" class="flex items-center justify-center gap-2 px-4 py-3 bg-white/5 hover:bg-white/10 border border-white/5 rounded-xl transition-all hover:scale-[1.02] text-sm font-medium text-zinc-300 hover:text-white">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.399 1.02 0 2.047.133 3.006.4 2.29-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              GitHub
            </button>
          </div>
        </div>

        <!-- Status Message -->
        <div id="status-msg" class="mt-6 text-center text-xs font-mono h-4 text-transparent transition-colors duration-300">
          &nbsp;
        </div>

        <!-- Success State (hidden by default) -->
        <div id="success-section" class="hidden mt-6 text-center space-y-3">
          <div class="w-12 h-12 rounded-full bg-green-500/10 border border-green-500/30 flex items-center justify-center mx-auto">
            <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <p id="success-text" class="text-green-400 text-sm font-medium"></p>
          <p class="text-zinc-500 text-xs">You can now close this tab and return to the terminal.</p>
        </div>
        
        <div class="mt-8 pt-6 border-t border-white/5 text-center">
          <a href="/" class="text-xs text-zinc-600 hover:text-zinc-400 transition-colors">Return to Home</a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<!-- Config passed to client script via data attributes (no inline secrets) -->
<div
  id="login-config"
  data-supabase-url={supabaseUrl}
  data-supabase-key={supabaseKey}
  class="hidden"
></div>

<script>
  import {
    createClient,
    type SupabaseClient,
    type Provider,
    type User,
    type Session,
  } from '@supabase/supabase-js';

  // ─── Types ──────────────────────────────────────────────────────────────────

  interface AuthPayload {
    provider: string;
    wallet?: string;
    user?: User;
    session?: Session;
  }

  // ─── Init ───────────────────────────────────────────────────────────────────

  const configEl   = document.getElementById('login-config') as HTMLElement;
  const supabaseUrl = configEl?.dataset.supabaseUrl ?? '';
  const supabaseKey = configEl?.dataset.supabaseKey ?? '';

  // Read session_id from URL once — this never changes during the page lifetime
  const sessionId = new URLSearchParams(window.location.search).get('session_id');

  let supabase: SupabaseClient | null = null;
  if (supabaseUrl && supabaseKey) {
    supabase = createClient(supabaseUrl, supabaseKey);
  } else {
    console.warn('[AuraOS] Supabase credentials missing.');
  }

  // ─── UI helpers ─────────────────────────────────────────────────────────────

  const statusEl      = document.getElementById('status-msg')     as HTMLElement;
  const authSection   = document.getElementById('auth-section')   as HTMLElement;
  const successSection = document.getElementById('success-section') as HTMLElement;
  const successText   = document.getElementById('success-text')   as HTMLElement;

  function showStatus(msg: string, type: 'info' | 'error' | 'success' = 'info') {
    if (!statusEl) return;
    statusEl.textContent = msg;
    statusEl.className = 'mt-6 text-center text-xs font-mono h-4 transition-colors duration-300 ' + (
      type === 'error'   ? 'text-red-400'   :
      type === 'success' ? 'text-green-400' :
                           'text-zinc-400'
    );
  }

  function showSuccess(label: string) {
    authSection?.classList.add('hidden');
    statusEl?.classList.add('hidden');
    successSection?.classList.remove('hidden');
    if (successText) successText.textContent = `Connected as ${label}`;
  }

  function setButtonsDisabled(disabled: boolean) {
    ['btn-web3', 'btn-google', 'btn-github'].forEach(id => {
      const el = document.getElementById(id) as HTMLButtonElement | null;
      if (el) el.disabled = disabled;
    });
  }

  // ─── Core: push payload to Supabase so CLI can pick it up ───────────────────

  async function syncWithCLI(payload: AuthPayload): Promise<boolean> {
    // No session_id → user opened login page directly (not from CLI)
    // Just redirect to dashboard after login
    if (!sessionId) return false;

    if (!supabase) {
      showStatus('Auth service not configured', 'error');
      return false;
    }

    showStatus('Syncing with Aura OS CLI…');

    const { error } = await supabase
      .from('cli_sessions')
      .update({ payload: payload as any })
      .eq('session_id', sessionId);

    if (error) {
      console.error('[AuraOS] CLI sync failed:', error);
      showStatus('Failed to sync with CLI', 'error');
      return false;
    }

    return true;
  }

  async function handleAuthSuccess(payload: AuthPayload) {
    setButtonsDisabled(true);

    const label =
      payload.wallet ??
      payload.user?.email ??
      payload.user?.id ??
      'unknown';

    const synced = await syncWithCLI(payload);

    if (synced) {
      // CLI flow: show "close this tab" message
      showSuccess(label);
    } else {
      // Direct web login: redirect to dashboard
      showStatus('Logged in! Redirecting…', 'success');
      setTimeout(() => (window.location.href = '/dashboard'), 1000);
    }
  }

  // ─── OAuth (Google / GitHub) ─────────────────────────────────────────────────
  //
  // Flow:
  //   1. User clicks → signInWithOAuth (redirectTo = /login/callback?session_id=...)
  //   2. Supabase redirects back to /login/callback
  //   3. /login/callback exchanges the code, then redirects back here with session active
  //   4. On page load we check getSession() and call handleAuthSuccess

  async function handleOAuth(provider: Provider) {
    if (!supabase) {
      showStatus('Auth service not configured', 'error');
      return;
    }

    showStatus(`Redirecting to ${provider}…`);
    setButtonsDisabled(true);

    // Build the callback URL, carrying session_id through the whole OAuth round-trip
    const callbackUrl = new URL('/login/callback', window.location.origin);
    if (sessionId) callbackUrl.searchParams.set('session_id', sessionId);

    const { error } = await supabase.auth.signInWithOAuth({
      provider,
      options: {
        redirectTo: callbackUrl.toString(),
      },
    });

    if (error) {
      showStatus(error.message, 'error');
      setButtonsDisabled(false);
    }
    // If no error: browser is navigating away — nothing more to do
  }

  document.getElementById('btn-google')?.addEventListener('click', () => handleOAuth('google'));
  document.getElementById('btn-github')?.addEventListener('click', () => handleOAuth('github'));

  // ─── MetaMask ────────────────────────────────────────────────────────────────

  document.getElementById('btn-web3')?.addEventListener('click', async () => {
    // @ts-ignore
    if (typeof window.ethereum === 'undefined') {
      showStatus('MetaMask not detected', 'error');
      return;
    }

    try {
      showStatus('Requesting wallet access…');
      setButtonsDisabled(true);

      // @ts-ignore
      const accounts: string[] = await window.ethereum.request({
        method: 'eth_requestAccounts',
      });

      if (!accounts[0]) throw new Error('No account returned');

      await handleAuthSuccess({ provider: 'metamask', wallet: accounts[0] });
    } catch (err) {
      showStatus((err as Error).message || 'Wallet request rejected', 'error');
      setButtonsDisabled(false);
    }
  });

  // ─── Check for existing OAuth session on page load ───────────────────────────
  //
  // This handles the case where Supabase has just redirected back after OAuth.
  // Supabase sets the session in localStorage automatically; we just read it.

  if (supabase) {
    supabase.auth.getSession().then(async ({ data: { session }, error }) => {
      if (error) {
        console.error('[AuraOS] getSession error:', error);
        return;
      }
      if (!session) return; // No active session — normal first load

      // Active session found (OAuth just completed)
      await handleAuthSuccess({
        provider: session.user.app_metadata?.provider ?? 'oauth',
        user:     session.user,
        session,
      });
    });
  }
</script>

<style>
  .animate-pulse-slow {
    animation: pulse 8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.2; transform: scale(1); }
    50%       { opacity: 0.25; transform: scale(1.1); }
  }
</style>