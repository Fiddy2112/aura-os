---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="404 - Page Not Found | Aura OS">
  <Navbar />
  
  <main class="relative min-h-screen flex items-center justify-center overflow-hidden bg-black select-none pt-20">
    <!-- Dynamic Background -->
    <div class="absolute inset-0 z-0">
      <div class="absolute top-[30%] left-[30%] w-96 h-96 bg-purple-500/20 rounded-full blur-[120px] animate-pulse-slow"></div>
      <div class="absolute bottom-[30%] right-[30%] w-96 h-96 bg-blue-500/10 rounded-full blur-[120px] animate-pulse-slow" style="animation-delay: 1s;"></div>
      <div class="absolute inset-0 grid-pattern opacity-20"></div>
    </div>

    <!-- 404 Container -->
    <div class="relative z-10 w-full max-w-lg p-6 animate-fade-in text-center">
      
      <!-- 404 Graphic -->
      <div class="mb-8 relative inline-block">
        <h1 class="text-8xl md:text-9xl font-black text-transparent bg-clip-text bg-gradient-to-r from-purple-500 to-cyan-500 animate-pulse-slow filter drop-shadow-[0_0_30px_rgba(168,85,247,0.4)]">
          404
        </h1>
        <div class="absolute inset-x-0 bottom-2 h-1 bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
      </div>

      <!-- Content -->
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 tracking-tight">Signal Lost</h2>
      <p class="text-zinc-400 text-lg mb-10 max-w-md mx-auto">
        The node you are trying to reach has disconnected or does not exist in the current network topology.
      </p>

      <!-- Action -->
      <a href="/" class="group relative inline-flex items-center justify-center overflow-hidden rounded-full p-4 px-8 font-medium bg-white text-black hover:scale-105 transition-transform duration-300 shadow-[0_0_40px_rgba(255,255,255,0.2)]">
        <span class="absolute inset-0 flex h-full w-full justify-center [transform:skew(-12deg)_translateX(-100%)] group-hover:duration-1000 group-hover:[transform:skew(-12deg)_translateX(100%)]">
            <div class="relative h-full w-8 bg-white/30"></div>
        </span>
        <span class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Return to Nexus
        </span>
      </a>

      <!-- Terminal subtle detail -->
      <div class="mt-16 text-center text-xs font-mono text-zinc-600">
        <span class="mr-2">&gt;</span>ERR_CONNECTION_REFUSED
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>

<style>
  .animate-pulse-slow {
    animation: pulse 8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.05); }
  }
</style>
