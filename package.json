{
  "name": "@felizz23/aura-os",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.2.4",
  "description": "Autonomous AI Agent Network Manager for Web3",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aura-os/aura-os.git"
  },
  "main": "dist/src/index.js",
  "bin": {
    "aura": "bin/aura"
  },
  "files": [
    "dist",
    "bin",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "cli:dev": "tsx src/index.ts",
    "test": "jest",
    "web:dev": "npm run dev --prefix web",
    "web:build": "npm run build --prefix web",
    "web:preview": "npm run preview --prefix web",
    "aura:chat": "npm run cli:dev -- chat",
    "aura:setup": "npm run cli:dev -- setup",
    "aura:status": "npm run cli:dev -- status",
    "aura:research": "npm run cli:dev -- research",
    "aura:news": "npm run cli:dev -- news",
    "aura:watch": "npm run cli:dev -- watch",
    "aura:wallet": "npm run cli:dev -- wallet",
    "aura:debank": "npm run cli:dev -- debank",
    "aura:reset-password": "npm run cli:dev -- reset-password",
    "aura:login": "npm run cli:dev -- login",
    "aura:dashboard": "npm run cli:dev -- dashboard",
    "aura:chain": "npm run cli:dev -- dev chain",
    "aura:info": "npm run cli:dev -- dev info",
    "aura:risk": "npm run cli:dev -- dev risk",
    "aura:privilege": "npm run cli:dev -- dev privilege",
    "aura:analyze": "npm run cli:dev -- dev analyze",
    "aura:run": "npm run cli:dev -- run",
    "aura:help": "npm run cli:dev -- help"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@oclif/core": "^3.0.0",
    "@supabase/supabase-js": "^2.93.2",
    "@tavily/core": "^0.7.1",
    "axios": "^1.13.4",
    "boxen": "^8.0.1",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "clipboardy": "^5.2.1",
    "conf": "^11.0.2",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.3",
    "gradient-string": "^3.0.0",
    "groq-sdk": "^0.37.0",
    "inquirer": "^8.2.7",
    "open": "^11.0.0",
    "openai": "^4.104.0",
    "ora": "^9.3.0",
    "viem": "2.21.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.1",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
